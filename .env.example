# WandB configuration
# Copy this file to .env and fill in your credentials
# Get your API key from https://wandb.ai/authorize
WANDB_API_KEY=your-wandb-api-key-here
WANDB_PROJECT=mashup

# HuggingFace token for gated models (e.g., Gemma)
# Get your token from https://huggingface.co/settings/tokens
# Required for Gemma models - accept license at https://huggingface.co/google/gemma-3-4b-it
HF_TOKEN=your-huggingface-token-here

# Disable Axolotl telemetry
AXOLOTL_DO_NOT_TRACK=1

# Usage:
#   cp .env.example .env
#   # Edit .env with your credentials
#   uv run python scripts/train.py configs/gemma3_4b_lora.yaml
